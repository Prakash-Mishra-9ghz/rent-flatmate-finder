# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rent_flatmate_finder"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Long random secret for signing JWT cookies
JWT_SECRET="replace-with-a-long-random-string"

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# "anthropic"  → uses Claude (claude-3-5-haiku-20241022 by default)
# "openai"     → uses GPT-4o-mini by default
# "none"       → skips LLM and always uses rule-based fallback
LLM_PROVIDER="anthropic"

# Anthropic (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-haiku-20241022"   # optional override

# OpenAI (only needed when LLM_PROVIDER=openai)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"                     # optional override

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# If left blank, the app uses a free Ethereal test account automatically.
# Check server logs for the Ethereal preview URL of each sent email.
#
# For production, supply real SMTP credentials:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM='"Rent & Flatmate Finder" <no-reply@yourdomain.com>'

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# Compatibility score threshold above which email alert is sent to owner
HIGH_COMPATIBILITY_THRESHOLD=80
